rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Rooms collection rules
    match /rooms/{roomId} {
      // Allow creation if user is authenticated and sets themselves as the owner
      allow create: if request.auth != null 
                    && request.resource.data.userId == request.auth.uid;
      
      // Allow reading, updating, and deleting only if the authenticated user owns the room
      allow read, update, delete: if request.auth != null 
                                  && resource.data.userId == request.auth.uid;
      
      // Messages subcollection rules
      match /messages/{messageId} {
        // Allow reading and writing messages only if the user owns the parent room
        allow read, write: if request.auth != null 
                           && get(/databases/$(database)/documents/rooms/$(roomId)).data.userId == request.auth.uid;
      }
    }

    // Vocabularies collection rules
    match /vocabularies/{vocabId} {
      // Allow creation if user is authenticated and sets themselves as the owner
      allow create: if request.auth != null 
                    && request.resource.data.userId == request.auth.uid;
      
      // Allow reading, updating, and deleting only if the authenticated user owns the vocabulary entry
      allow read, update, delete: if request.auth != null 
                                  && resource.data.userId == request.auth.uid;
    }
  }
}
